# ==========================================
# CONFIGURACIÓN DE BASE DE DATOS - SUPABASE
# ==========================================
# Reemplaza [USER], [PASSWORD], [HOST] y [DB_NAME] con tus datos de Supabase
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres"

# ==========================================
# CONFIGURACIÓN DE SEGURIDAD JWT
# ==========================================
# Clave secreta para firmar tokens JWT (usa una clave fuerte en producción)
SECRET_KEY="IAIM_SECRET_KEY_SUPER_SECRETA_CAMBIAR_EN_PRODUCCION"

# Tiempo de expiración del token en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# CONFIGURACIÓN DEL SERVIDOR
# ==========================================
# Puerto donde correrá la API (opcional, por defecto 8000)
PORT=8000

# Host de la API (opcional, por defecto 127.0.0.1)
HOST=127.0.0.1

# Entorno de ejecución (development, production)
ENVIRONMENT=development

# ==========================================
# CONFIGURACIÓN DE TELEGRAM BOT (OPCIONAL)
# ==========================================
# Token del bot de Telegram para notificaciones
TELEGRAM_BOT_TOKEN=""

# Chat ID para recibir notificaciones
TELEGRAM_CHAT_ID=""

# ==========================================
# CONFIGURACIÓN ADICIONAL
# ==========================================
# URL del frontend para CORS (opcional)
FRONTEND_URL="http://localhost:3000"

# Email para notificaciones del sistema (opcional)
ADMIN_EMAIL="admin@iaim.aero"
