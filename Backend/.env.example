# ==========================================
# IAIM - Backend (FastAPI)
# ==========================================

# ------------------------------------------
# Base de datos PostgreSQL
# ------------------------------------------
# En Replit: la provisiona Replit automáticamente.
# En Render: pega aquí la URL del addon Postgres o de tu DB externa.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ------------------------------------------
# Seguridad / JWT
# ------------------------------------------
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY="cambia-esto-por-una-clave-aleatoria-larga"

# Tiempo de expiración del token de acceso (minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------
# Logging
# ------------------------------------------
# Nivel raíz del logger. Valores: DEBUG | INFO | WARNING | ERROR | CRITICAL
# DEBUG incluye también los health checks; INFO los omite (recomendado en prod).
LOG_LEVEL=INFO

# ------------------------------------------
# Servidor
# ------------------------------------------
# Render inyecta PORT automáticamente. Localmente puedes omitirlo.
# El comando recomendado en Render es:
#   uvicorn API.main:app --host 0.0.0.0 --port $PORT
PORT=8000

# ------------------------------------------
# CORS
# ------------------------------------------
# URL pública del frontend desplegado en Vercel.
# Acepta una sola URL o varias separadas por coma.
# Si se deja vacía, el backend permite cualquier origen (solo dev).
# Ejemplo: FRONTEND_URL="https://iaim.vercel.app,https://iaim-staging.vercel.app"
FRONTEND_URL=""

# ------------------------------------------
# Telegram Bot (opcional, no se usa en el deploy básico)
# ------------------------------------------
TELEGRAM_BOT_TOKEN=""
